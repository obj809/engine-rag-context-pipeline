# Copy to .env and fill in. The engine reads its own .env first, then falls back
# to the umbrella project's .env during the multi-repo split.
# OPENAI_API_KEY is needed by the REPL (ask.py); the eval harness needs only DATABASE_URL.
OPENAI_API_KEY=sk-...
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag
